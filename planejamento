        const cartao = MONTHS.map(m=>getTotalGastosCartaoMes(m));
        const necessidades = MONTHS.map(m=>getTotalNecessidades(m));
        const desejos = MONTHS.map(m=>getTotalDesejos(m));
        const investimentos = MONTHS.map(m=>getTotalInvestimentosMensal(m));
        const saldos = MONTHS.map(m=>getSaldo(m));
        
        let html = `<div class="card"><div class="card-title">📈 EVOLUÇÃO 2026</div><div class="chart-container"><canvas id="annualChart"></canvas></div></div>
        <div class="card"><div class="card-title">📊 RESUMO ANUAL</div><div class="scrollable-table"> <table><thead><tr><th>Mês</th><th>Receita</th><th>Cartão</th><th>Necessidades</th><th>Desejos</th><th>Investimentos</th><th>Total</th><th>Saldo</th></tr></thead><tbody>${MONTHS.map((m,i)=>`<tr><td>${MONTH_NAMES[i]}</td><td>${formatCurrency(receitas[i])}</td><td>${formatCurrency(cartao[i])}</td><td>${formatCurrency(necessidades[i])}</td><td>${formatCurrency(desejos[i])}</td><td>${formatCurrency(investimentos[i])}</td><td>${formatCurrency(cartao[i]+necessidades[i]+desejos[i]+investimentos[i])}</td><td style="color:${saldos[i]>=0?'#06D6A0':'#EF476F'}">${formatCurrency(saldos[i])}</td></tr>`).join('')}</tbody></table></div></div>`;
        
        const totalReceita = receitas.reduce((a,b)=>a+b,0);
        const totalNec = necessidades.reduce((a,b)=>a+b,0);
        const totalDes = desejos.reduce((a,b)=>a+b,0);
        const totalInv = investimentos.reduce((a,b)=>a+b,0);
        
        html += `<div class="card"><div class="card-title">📐 ANÁLISE 50/30/20 ANUAL</div><div class="indicators-grid">
        <div class="indicator-card"><div class="indicator-title">Necessidades (50%)</div><div class="indicator-value">${formatCurrency(totalNec)}</div><div>${formatPercent(totalNec/totalReceita)} da receita</div><div>Meta: 50% (${formatCurrency(totalReceita*0.5)})</div><div class="${totalNec<=totalReceita*0.5?'status-ok':'status-warning'}">${totalNec<=totalReceita*0.5?'✅ OK':'⚠️ Acima'}</div></div>
        <div class="indicator-card"><div class="indicator-title">Desejos (30%)</div><div class="indicator-value">${formatCurrency(totalDes)}</div><div>${formatPercent(totalDes/totalReceita)} da receita</div><div>Meta: 30% (${formatCurrency(totalReceita*0.3)})</div><div class="${totalDes<=totalReceita*0.3?'status-ok':'status-warning'}">${totalDes<=totalReceita*0.3?'✅ OK':'⚠️ Acima'}</div></div>
        <div class="indicator-card"><div class="indicator-title">Investimentos (20%)</div><div class="indicator-value">${formatCurrency(totalInv)}</div><div>${formatPercent(totalInv/totalReceita)} da receita</div><div>Meta: 20% (${formatCurrency(totalReceita*0.2)})</div><div class="${totalInv>=totalReceita*0.2?'status-ok':'status-warning'}">${totalInv>=totalReceita*0.2?'✅ OK':'⚠️ Abaixo'}</div></div></div></div>`;
        return { html, receitas, cartao, necessidades, desejos, investimentos };
    }

    function renderInvestimentos() {
        function renderTipo(tipo, titulo, cor) {
            const items = investments[tipo];
            let html = `<div class="card"><div class="card-title" style="color:${cor}">${titulo}</div><div class="scrollable-table"> <table><thead>
                            <tr><th>Ativo</th><th>Quantidade</th><th>Preço Médio</th><th>Valor Atual</th><th>Total Investido</th><th>Valorização</th><th>Ações</th></tr>
                        </thead><tbody>`;
            items.forEach((item, idx) => {
                const investido = (item.quantidade || 1) * (item.preco_medio || item.valor_investido || 0);
                const atual = (item.quantidade || 1) * (item.valor_atual || item.valor_investido || 0);
                const variacao = atual - investido;
                html += `<tr>
                            <td class="text-left">${escapeHtml(item.nome)}</td>
                            <td>${item.quantidade || '-'}</td>
                            <td>${formatCurrency(item.preco_medio || item.valor_investido)}</td>
                            <td>${formatCurrency(item.valor_atual || item.valor_investido)}</td>
                            <td>${formatCurrency(investido)}</td>
                            <td style="color:${variacao>=0?'#06D6A0':'#EF476F'}">${formatCurrency(variacao)}</td>
                            <td>
                                <span class="action-icons" onclick="editarInvestimento('${tipo}',${idx})">✏️</span>
                                <span class="action-icons" onclick="excluirInvestimento('${tipo}',${idx})">🗑️</span>
                            </td>
                           </tr>`;
            });
            html += `<tr><td colspan="7"><div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(100px,1fr));gap:10px">
                        <input type="text" id="novo_nome_${tipo}" placeholder="Nome">
                        <input type="number" id="novo_qtde_${tipo}" placeholder="Quantidade" step="0.01">
                        <input type="number" id="novo_preco_${tipo}" placeholder="Preço" step="0.01">
                        <input type="number" id="novo_atual_${tipo}" placeholder="Atual" step="0.01">
                        <button onclick="adicionarInvestimento('${tipo}')">+ Adicionar</button>
                    </div></td></tr>
                    </tbody>
                </div></div>`;
            return html;
        }
        let totalGeral = 0, totalInvestido = 0;
        ['fiis','acoes','tesouro_direto'].forEach(t => { investments[t].forEach(i => { totalInvestido += (i.quantidade||1)*(i.preco_medio||i.valor_investido||0); totalGeral += (i.quantidade||1)*(i.valor_atual||i.valor_investido||0); }); });
        return `<div class="card"><div class="card-title">💎 CARTEIRA DE INVESTIMENTOS</div><div class="indicators-grid">
                    <div class="indicator-card"><div class="indicator-title">Total Investido</div><div class="indicator-value">${formatCurrency(totalInvestido)}</div></div>
                    <div class="indicator-card"><div class="indicator-title">Valor Atual</div><div class="indicator-value" style="color:${totalGeral>=totalInvestido?'#06D6A0':'#EF476F'}">${formatCurrency(totalGeral)}</div></div>
                    <div class="indicator-card"><div class="indicator-title">Rentabilidade</div><div class="indicator-value" style="color:${totalGeral>=totalInvestido?'#06D6A0':'#EF476F'}">${formatCurrency(totalGeral-totalInvestido)} (${formatPercent((totalGeral-totalInvestido)/totalInvestido)})</div></div>
                </div></div>${renderTipo('fiis','🏢 Fundos Imobiliários','#FFD166')}${renderTipo('acoes','📈 Ações','#06D6A0')}${renderTipo('tesouro_direto','🏦 Tesouro Direto','#00B4D8')}`;
    }

    function renderGuia() {
        return `<div class="card">
                    <div class="card-title">📘 GUIA DO SISTEMA - REGRA 50/30/20</div>
                    
                    <div class="exemplo-box">
                        <div class="exemplo-titulo">💰 COMO FUNCIONA A REGRA 50/30/20?</div>
                        <p>Distribua sua renda mensal da seguinte forma:</p>
                        <ul style="margin-left: 20px; margin-top: 10px;">
                            <li><strong style="color: #00B4D8;">50% NECESSIDADES</strong> - Gastos essenciais para viver</li>
                            <li><strong style="color: #FFD166;">30% DESEJOS</strong> - Gastos para lazer e conforto</li>
                            <li><strong style="color: #06D6A0;">20% INVESTIMENTOS</strong> - Gastos para o futuro/liberdade financeira</li>
                        </ul>
                    </div>

                    <div class="exemplo-box">
                        <div class="exemplo-titulo">💳 COMO CLASSIFICAR OS GASTOS DO CARTÃO?</div>
                        <p>Ao adicionar uma compra no cartão, selecione a categoria correta:</p>
                        <table style="margin-top: 10px; width: 100%;">
                            <thead><tr><th>Exemplo de Gasto</th><th>Categoria</th><th>Percentual</th></tr></thead>
                            <tbody>
                                <tr style="background: rgba(0,180,216,0.2);"><td>🛒 Mercado, 🏠 Aluguel, 💡 Contas, 🚗 Combustível</td><td>Necessidade</td><td>50%</td></tr>
                                <tr style="background: rgba(255,209,102,0.2);"><td>📺 Netflix, 🍔 Restaurante, ✈️ Viagem, 👕 Roupas</td><td>Desejo</td><td>30%</td></tr>
                                <tr style="background: rgba(6,214,160,0.2);"><td>📚 Cursos, 💻 Notebook p/ trabalho, 💎 Ações</td><td>Investimento</td><td>20%</td></tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="exemplo-box">
                        <div class="exemplo-titulo">🎯 EXEMPLO PRÁTICO</div>
                        <p>Renda mensal: <strong>R$ 6.000</strong></p>
                        <ul style="margin-left: 20px; margin-top: 10px;">
                            <li><strong style="color: #00B4D8;">Necessidades (R$ 3.000 - 50%)</strong><br>
                                Aluguel: R$ 1.500 • Mercado: R$ 800 • Contas: R$ 400 • Transporte: R$ 300</li>
                            <li><strong style="color: #FFD166;">Desejos (R$ 1.800 - 30%)</strong><br>
                                Streaming: R$ 90 • Restaurantes: R$ 400 • Viagem: R$ 500 • Lazer: R$ 810</li>
                            <li><strong style="color: #06D6A0;">Investimentos (R$ 1.200 - 20%)</strong><br>
                                Curso: R$ 300 • Ações: R$ 500 • Reserva Emergência: R$ 400</li>
                        </ul>
                    </div>

                    <div class="exemplo-box">
                        <div class="exemplo-titulo">⚡ FUNCIONALIDADES DO SISTEMA</div>
                        <ul style="margin-left: 20px;">
                            <li><strong>Inserção Rápida:</strong> Use os botões coloridos (50%/30%/20%) para adicionar gastos rapidamente</li>
                            <li><strong>Replicação entre meses:</strong> Copie todos os itens de um mês para o próximo com 1 clique</li>
                            <li><strong>Múltiplos Cartões:</strong> Gerencie vários cartões com limites diferentes</li>
                            <li><strong>Classificação de compras:</strong> Ao adicionar uma compra no cartão, defina se é Necessidade/Desejo/Investimento</li>
                            <li><strong>Backup de dados:</strong> Use os botões Exportar/Importar para segurança</li>
                            <li><strong>Acompanhamento de investimentos:</strong> Controle FIIs, Ações e Tesouro Direto</li>
                        </ul>
                    </div>

                    <div class="exemplo-box">
                        <div class="exemplo-titulo">❓ PERGUNTAS FREQUENTES</div>
                        <p><strong>🔹 Um gasto pode ser classificado de forma diferente?</strong><br>
                        Sim! Por exemplo: Um notebook pode ser 20% se for para trabalho, mas 30% se for para lazer.</p>
                        
                        <p><strong>🔹 E se a soma dos percentuais não der exato?</strong><br>
                        A regra é flexível. O importante é estar próximo: 45-55%, 25-35%, 15-25%.</p>
                        
                        <p><strong>🔹 Onde entram as parcelas do cartão?</strong><br>
                        Cada parcela é contabilizada no mês em que vence, seguindo a categoria definida na compra.</p>
                    </div>
                </div>`;
    }

    window.toggleParcelas = function() {
        const parcelasGroup = document.getElementById('parcelas_group');
        if (parcelasGroup) {
            parcelasGroup.style.display = document.getElementById('novo_tipo').value === 'parcelado' ? 'block' : 'none';
        }
    };

    window.adicionarCompraCartao = function() {
        if (!selectedCardId && creditCards.length === 0) {
            showToast("Cadastre um cartão primeiro!", "erro");
            return;
        }
        const nome = document.getElementById('nova_descricao')?.value;
        const valor = parseFloat(document.getElementById('novo_valor')?.value);
        const tipo = document.getElementById('novo_tipo')?.value;
        const parcelas = tipo === 'parcelado' ? parseInt(document.getElementById('novo_parcelas')?.value) : 0;
        const dataInicio = document.getElementById('novo_mes_inicio')?.value;
        const categoria = document.getElementById('nova_categoria')?.value;
        
        if (!nome || isNaN(valor)) { showToast("Preencha todos os campos", "erro"); return; }
        
        creditCardExpenses.push({ 
            id: Date.now(), 
            cartaoId: selectedCardId, 
            nome, 
            valor, 
            tipo, 
            parcelas, 
            parcelaAtual: 1, 
            dataInicio, 
            categoria: categoria 
        });
        saveAllData();
        refreshCurrentTab();
        showToast(`Compra "${nome}" adicionada como ${categoria === 'necessidade' ? 'Necessidade (50%)' : (categoria === 'desejo' ? 'Desejo (30%)' : 'Investimento (20%)')}!`);
    };

    window.excluirCompraCartao = function(id) { 
        if(confirm('Excluir esta compra?')){ 
            creditCardExpenses = creditCardExpenses.filter(e => e.id !== id);
            saveAllData(); 
            refreshCurrentTab(); 
            showToast("Compra removida!");
        } 
    };

    window.editarCompraCartao = function(id) {
        const expense = creditCardExpenses.find(e => e.id === id);
        if (!expense) return;
        const n = prompt('Nova descrição:', expense.nome); if(n && n.trim()) expense.nome = n.trim();
        const v = prompt('Novo valor:', expense.valor); if(v && !isNaN(parseFloat(v))) expense.valor = parseFloat(v);
        saveAllData(); 
        refreshCurrentTab();
        showToast("Compra atualizada!");
    };

    window.atualizarReceita = function(mes, valor) { 
        monthlyData[mes].receita = parseFloat(valor) || 0; 
        saveAllData(); 
        refreshCurrentTab(); 
    };

    window.adicionarItem = function(mes, categoria) {
        const nomeInput = document.getElementById(`novo_nome_${categoria}_${mes}`);
        const valorInput = document.getElementById(`novo_valor_${categoria}_${mes}`);
        if (!nomeInput || !valorInput) { 
            showToast("Erro ao encontrar campos do formulário", "erro"); 
            return; 
        }
        const nome = nomeInput.value.trim();
        const valor = parseFloat(valorInput.value);
        if (!nome || isNaN(valor) || valor <= 0) { 
            showToast("Preencha todos os campos corretamente", "erro"); 
            return; 
        }
        if (!monthlyData[mes]) monthlyData[mes] = getDefaultMonthlyData(mes);
        if (!monthlyData[mes][categoria]) monthlyData[mes][categoria] = [];
        monthlyData[mes][categoria].push({ nome, valor });
        saveAllData();
        refreshCurrentTab();
        showToast("Item adicionado!");
    };

    window.adicionarInvestimento = function(tipo) {
        const nome = document.getElementById(`novo_nome_${tipo}`)?.value;
        const quantidade = parseFloat(document.getElementById(`novo_qtde_${tipo}`)?.value);
        const preco = parseFloat(document.getElementById(`novo_preco_${tipo}`)?.value);
        const atual = parseFloat(document.getElementById(`novo_atual_${tipo}`)?.value);
        if (!nome || isNaN(quantidade) || isNaN(preco) || isNaN(atual)) { 
            showToast("Preencha todos os campos", "erro"); 
            return; 
        }
        investments[tipo].push({ nome, quantidade, preco_medio: preco, valor_atual: atual });
        saveAllData(); 
        refreshCurrentTab();
        showToast("Investimento adicionado!");
    };

    window.editarInvestimento = function(tipo, idx) {
        const i = investments[tipo][idx];
        if (!i) return;
        const n = prompt('Nome:', i.nome); if(n && n.trim()) i.nome = n.trim();
        const q = prompt('Quantidade:', i.quantidade); if(q && !isNaN(parseFloat(q))) i.quantidade = parseFloat(q);
        const p = prompt('Preço médio:', i.preco_medio); if(p && !isNaN(parseFloat(p))) i.preco_medio = parseFloat(p);
        const a = prompt('Valor atual:', i.valor_atual); if(a && !isNaN(parseFloat(a))) i.valor_atual = parseFloat(a);
        saveAllData(); 
        refreshCurrentTab();
        showToast("Investimento atualizado!");
    };

    window.excluirInvestimento = function(tipo, idx) { 
        if(confirm('Excluir este investimento?')){ 
            investments[tipo].splice(idx,1); 
            saveAllData(); 
            refreshCurrentTab(); 
            showToast("Investimento removido!");
        } 
    };

    let chart1 = null, chart2 = null;

    function initCharts() {
        const proj = renderProjecaoMensal();
        const anual = renderResumoAnual();
        setTimeout(() => {
            const ctx1 = document.getElementById('cardProjectionChart');
            if(ctx1 && proj.projectionData) { 
                if(chart1) chart1.destroy(); 
                chart1 = new Chart(ctx1, { 
                    type:'line', 
                    data:{ 
                        labels:MONTH_NAMES, 
                        datasets:[{ 
                            label:'Gastos no Cartão (Total)', 
                            data:proj.projectionData, 
                            borderColor:'#00B4D8', 
                            backgroundColor:'rgba(0,180,216,0.1)', 
                            tension:0.4, 
                            fill:true 
                        }] 
                    }, 
                    options:{ 
                        responsive:true, 
                        plugins:{ 
                            tooltip:{ 
                                callbacks:{ 
                                    label:(ctx)=>`${ctx.dataset.label}: ${formatCurrency(ctx.raw)}` 
                                } 
                            } 
                        }, 
                        scales:{ 
                            y:{ 
                                ticks:{ 
                                    callback:(v)=>formatCurrency(v) 
                                } 
                            } 
                        } 
                    } 
                }); 
            }
            const ctx2 = document.getElementById('annualChart');
            if(ctx2 && anual.receitas) { 
                if(chart2) chart2.destroy(); 
                chart2 = new Chart(ctx2, { 
                    type:'line', 
                    data:{ 
                        labels:MONTH_NAMES, 
                        datasets:[
                            { label:'Receita', data:anual.receitas, borderColor:'#06D6A0', tension:0.4, fill:true, backgroundColor:'rgba(6,214,160,0.1)' },
                            { label:'Gastos Cartão', data:anual.cartao, borderColor:'#00B4D8', tension:0.4 },
                            { label:'Necessidades (50%)', data:anual.necessidades, borderColor:'#00B4D8', tension:0.4 },
                            { label:'Desejos (30%)', data:anual.desejos, borderColor:'#FFD166', tension:0.4 },
                            { label:'Investimentos (20%)', data:anual.investimentos, borderColor:'#06D6A0', tension:0.4 }
                        ] 
                    }, 
                    options:{ 
                        responsive:true, 
                        plugins:{ 
                            tooltip:{ 
                                callbacks:{ 
                                    label:(ctx)=>`${ctx.dataset.label}: ${formatCurrency(ctx.raw)}` 
                                } 
                            } 
                        }, 
                        scales:{ 
                            y:{ 
                                ticks:{ 
                                    callback:(v)=>formatCurrency(v) 
                                } 
                            } 
                        } 
                    } 
                }); 
            }
        }, 200);
    }

    function refreshCurrentTab() {
        const activeTab = document.querySelector('.tab-btn.active');
        if (activeTab) {
            const tabId = activeTab.getAttribute('data-tab-id');
            if (tabId === 'resumo') { 
                const anual = renderResumoAnual(); 
                document.getElementById('resumo').innerHTML = anual.html; 
                initCharts(); 
            }
            else if (tabId === 'cartao') { 
                document.getElementById('cartao').innerHTML = renderCreditCardManager(); 
                const proj = renderProjecaoMensal(); 
                document.getElementById('cartao').innerHTML += proj.html; 
                initCharts(); 
            }
            else if (tabId === 'investimentos') { 
                document.getElementById('investimentos').innerHTML = renderInvestimentos(); 
            }
            else if (tabId === 'guia') { 
                document.getElementById('guia').innerHTML = renderGuia(); 
            }
            else if (tabId.startsWith('mes_')) { 
                const mes = tabId.replace('mes_', ''); 
                const idx = MONTHS.indexOf(mes);
                currentMonthIndex = idx;
                document.getElementById(tabId).innerHTML = renderDetalhamentoMensal(mes, MONTH_NAMES[idx]); 
            }
        }
    }

    function initTabs() {
        loadInitialData();
        const tabsContainer = document.getElementById('tabs');
        const content = document.getElementById('content');
        const tabItems = [
            { id: 'resumo', label: '📊 Resumo Anual' },
            { id: 'cartao', label: '💳 Gestão de Cartões' },
            { id: 'investimentos', label: '💎 Investimentos' },
            { id: 'guia', label: '📘 Guia' },
            ...MONTHS.map((m,i) => ({ id: `mes_${m}`, label: `📅 ${MONTH_NAMES[i]}` }))
        ];
        
        tabsContainer.innerHTML = '';
        content.innerHTML = '';
        
        tabItems.forEach(tab => {
            const btn = document.createElement('button');
            btn.className = 'tab-btn';
            btn.textContent = tab.label;
            btn.setAttribute('data-tab-id', tab.id);
            btn.onclick = () => { 
                document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active')); 
                btn.classList.add('active'); 
                document.querySelectorAll('.tab-content').forEach(c=>c.classList.remove('active')); 
                document.getElementById(tab.id).classList.add('active'); 
                refreshCurrentTab(); 
            };
            tabsContainer.appendChild(btn);
        });
        
        tabItems.forEach(tab => {
            const div = document.createElement('div');
            div.id = tab.id;
            div.className = 'tab-content';
            if (tab.id === 'resumo') div.innerHTML = renderResumoAnual().html;
            else if (tab.id === 'cartao') div.innerHTML = renderCreditCardManager() + renderProjecaoMensal().html;
            else if (tab.id === 'investimentos') div.innerHTML = renderInvestimentos();
            else if (tab.id === 'guia') div.innerHTML = renderGuia();
            else { 
                const mes = tab.id.replace('mes_',''); 
                const idx = MONTHS.indexOf(mes); 
                div.innerHTML = renderDetalhamentoMensal(mes, MONTH_NAMES[idx]); 
            }
            content.appendChild(div);
        });
        
        const firstBtn = document.querySelector('.tab-btn');
        if (firstBtn) {
            firstBtn.classList.add('active');
            document.getElementById('resumo').classList.add('active');
        }
        setTimeout(() => { 
            initCharts(); 
            atualizarStorageBar(); 
        }, 300);
    }
    
    initTabs();
</script>
</body>
</html>
