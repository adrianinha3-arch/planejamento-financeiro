    window.adicionarItemRapido = function(mes, tipo) {
        let categoria = '';
        let titulo = '';
        let percentual = '';
        
        switch(tipo) {
            case '50':
                categoria = 'necessidades';
                titulo = 'Necessidades';
                percentual = '50%';
                break;
            case '30':
                categoria = 'desejos';
                titulo = 'Desejos';
                percentual = '30%';
                break;
            case '20':
                categoria = 'investimentos';
                titulo = 'Investimentos';
                percentual = '20%';
                break;
        }
        
        const nome = prompt(`📝 ${titulo} (${percentual})\n\nDigite a descrição do gasto/investimento:`);
        if (!nome || !nome.trim()) return;
        
        const valor = parseFloat(prompt(`💰 ${titulo}\n\nDigite o valor para "${nome}":`, "0"));
        if (isNaN(valor) || valor <= 0) {
            showToast("Valor inválido!", "erro");
            return;
        }
        
        if (!monthlyData[mes]) monthlyData[mes] = getDefaultMonthlyData(mes);
        if (!monthlyData[mes][categoria]) monthlyData[mes][categoria] = [];
        monthlyData[mes][categoria].push({ nome: nome.trim(), valor: valor });
        saveAllData();
        refreshCurrentTab();
        showToast(`✅ "${nome}" adicionado em ${titulo} (${percentual})!`);
    };

    window.replicarParaProximoMes = function(mesAtual) {
        const currentIndex = MONTHS.indexOf(mesAtual);
        if (currentIndex === -1 || currentIndex === MONTHS.length - 1) {
            showToast("Este é o último mês do ano! Não é possível replicar para frente.", "erro");
            return;
        }
        
        const proximoMes = MONTHS[currentIndex + 1];
        const mesAtualNome = MONTH_NAMES[currentIndex];
        const proximoMesNome = MONTH_NAMES[currentIndex + 1];
        
        if (!confirm(`📋 Replicar gastos de ${mesAtualNome} para ${proximoMesNome}?\n\nIsso irá COPIAR todos os itens das categorias:\n• Necessidades (50%)\n• Desejos (30%)\n• Investimentos (20%)\n\nOs dados existentes em ${proximoMesNome} serão MANTIDOS e os novos serão ADICIONADOS.`)) {
            return;
        }
        
        if (!monthlyData[proximoMes]) monthlyData[proximoMes] = getDefaultMonthlyData(proximoMes);
        
        const categorias = ['necessidades', 'desejos', 'investimentos'];
        let totalCopiados = 0;
        
        categorias.forEach(cat => {
            const itensOrigem = monthlyData[mesAtual][cat] || [];
            if (itensOrigem.length > 0) {
                if (!monthlyData[proximoMes][cat]) monthlyData[proximoMes][cat] = [];
                itensOrigem.forEach(item => {
                    monthlyData[proximoMes][cat].push({ ...item });
                    totalCopiados++;
                });
            }
        });
        
        saveAllData();
        refreshCurrentTab();
        showToast(`📋 Replicação concluída! ${totalCopiados} itens copiados para ${proximoMesNome}.`);
    };

