<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Planejamento Financeiro 2026 - Regra 50/30/20</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Calibri, 'Helvetica Neue', sans-serif;
            background: linear-gradient(135deg, #1A1A2E 0%, #16213E 100%);
            color: #FFFFFF;
            padding: 20px;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
        }

        .header {
            text-align: center;
            padding: 40px 20px;
            background: linear-gradient(135deg, #0F3460 0%, #1A1A2E 100%);
            border-radius: 20px;
            margin-bottom: 30px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.3);
            position: relative;
        }

        .header h1 {
            font-size: 2.5em;
            color: #00B4D8;
            margin-bottom: 10px;
        }

        .header p {
            color: #B0C4DE;
            font-size: 1.1em;
        }

        .storage-bar {
            position: absolute;
            top: 20px;
            right: 20px;
            background: rgba(0,0,0,0.5);
            padding: 8px 15px;
            border-radius: 20px;
            font-size: 12px;
            cursor: pointer;
        }

        .storage-bar:hover {
            background: rgba(0,0,0,0.7);
        }

        .action-buttons {
            display: flex;
            gap: 10px;
            justify-content: center;
            margin-top: 15px;
            flex-wrap: wrap;
        }

        .btn-export {
            background: #06D6A0;
        }

        .btn-export:hover {
            background: #05B386;
        }

        .btn-import {
            background: #FFD166;
            color: #1A1A2E;
        }

        .btn-import:hover {
            background: #E6BC5C;
        }

        .btn-reset {
            background: #EF476F;
        }

        .btn-reset:hover {
            background: #C0355A;
        }

        .tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 30px;
            flex-wrap: wrap;
            background: rgba(0,0,0,0.3);
            padding: 15px;
            border-radius: 15px;
        }

        .tab-btn {
            background: #0F3460;
            border: none;
            color: white;
            padding: 10px 20px;
            border-radius: 10px;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.3s;
            font-weight: bold;
        }

        .tab-btn:hover, .tab-btn.active {
            background: #00B4D8;
            transform: translateY(-2px);
        }

        .tab-content {
            display: none;
            animation: fadeIn 0.5s;
        }

        .tab-content.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .card {
            background: rgba(22,33,62,0.95);
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 20px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.2);
        }

        .card-title {
            font-size: 1.3em;
            color: #00B4D8;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid #00B4D8;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
        }

        .form-group {
            margin-bottom: 15px;
        }

        label {
            display: block;
            margin-bottom: 5px;
            color: #B0C4DE;
            font-weight: bold;
        }

        input, select, textarea {
            width: 100%;
            padding: 10px;
            border-radius: 8px;
            border: 1px solid #0F3460;
            background: #0D2137;
            color: white;
            font-size: 14px;
        }

        button {
            background: #00B4D8;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
            transition: all 0.3s;
        }

        button:hover {
            background: #0096B4;
            transform: translateY(-2px);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

        th {
            background: #0077B6;
            color: white;
            padding: 12px 8px;
            text-align: center;
        }

        td {
            padding: 8px;
            text-align: center;
            border-bottom: 1px solid #2C3E50;
        }

        .table-row-dark { background: #0D2137; }
        .table-row-light { background: #16213E; }
        .text-left { text-align: left; }
        .value-positive { color: #06D6A0; font-weight: bold; }
        .value-negative { color: #EF476F; }
        .status-ok { color: #06D6A0; }
        .status-warning { color: #FFD166; }

        .grid-2 {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
            gap: 20px;
        }

        .indicators-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }

        .indicator-card {
            background: linear-gradient(135deg, #0F3460 0%, #1A1A2E 100%);
            border-radius: 15px;
            padding: 20px;
            text-align: center;
        }

        .indicator-title {
            font-size: 0.9em;
            color: #B0C4DE;
            margin-bottom: 10px;
        }

        .indicator-value {
            font-size: 1.8em;
            font-weight: bold;
            margin-bottom: 5px;
        }

        .chart-container {
            background: rgba(255,255,255,0.05);
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .action-icons {
            cursor: pointer;
            margin: 0 5px;
            font-size: 18px;
            transition: all 0.2s;
            display: inline-block;
        }

        .action-icons:hover {
            opacity: 0.7;
            transform: scale(1.1);
        }

        .badge {
            display: inline-block;
            padding: 3px 8px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: bold;
        }

        .badge-recorrente { background: #FFD166; color: #1A1A2E; }
        .badge-parcelado { background: #06D6A0; color: #1A1A2E; }
        .badge-vista { background: #00B4D8; color: #1A1A2E; }
        .badge-50 { background: #00B4D8; color: white; }
        .badge-30 { background: #FFD166; color: #1A1A2E; }
        .badge-20 { background: #06D6A0; color: white; }

        .section-header {
            background: #0F3460;
            padding: 15px;
            border-radius: 10px;
            margin: 15px 0 10px 0;
            font-weight: bold;
            font-size: 1.1em;
        }

        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.9);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }

        .modal-content {
            background: #16213E;
            padding: 30px;
            border-radius: 20px;
            max-width: 500px;
            width: 90%;
            text-align: center;
        }

        .file-input {
            display: none;
        }

        .card-selector {
            background: #0F3460;
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 20px;
        }

        .card-badge {
            display: inline-block;
            background: #00B4D8;
            padding: 5px 12px;
            border-radius: 15px;
            margin: 5px;
            cursor: pointer;
            transition: all 0.3s;
        }

        .card-badge:hover, .card-badge.active {
            background: #06D6A0;
            transform: scale(1.05);
        }

        .delete-card {
            background: #EF476F;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 11px;
            margin-left: 8px;
            cursor: pointer;
        }

        .delete-card:hover {
            background: #C0355A;
        }

        .quick-add-section {
            background: #0F3460;
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 20px;
        }

        .quick-add-buttons {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 10px;
        }

        .btn-quick-50 { background: #00B4D8; }
        .btn-quick-30 { background: #FFD166; color: #1A1A2E; }
        .btn-quick-20 { background: #06D6A0; }

        .btn-replicate {
            background: #9C27B0;
        }

        .btn-replicate:hover {
            background: #7B1FA2;
        }

        .exemplo-box {
            background: rgba(0,0,0,0.3);
            border-left: 4px solid #00B4D8;
            padding: 15px;
            margin: 15px 0;
            border-radius: 8px;
        }

        .exemplo-titulo {
            color: #FFD166;
            font-weight: bold;
            margin-bottom: 10px;
        }

        @media (max-width: 768px) {
            .tabs { justify-content: center; }
            table { font-size: 11px; }
            .grid-2 { grid-template-columns: 1fr; }
            .storage-bar { position: static; margin-top: 15px; display: inline-block; }
        }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <h1>💰 PLANEJAMENTO FINANCEIRO | 2026</h1>
        <p>Regra 50/30/20 - Controle de Gastos e Investimentos</p>
        <div class="storage-bar" id="storageBar" onclick="showStorageInfo()">
            💾 Calculando espaço...
        </div>
        <div class="action-buttons">
            <button class="btn-export" onclick="exportarDados()">📤 Exportar Dados</button>
            <button class="btn-import" onclick="document.getElementById('fileInput').click()">📥 Importar Dados</button>
            <button class="btn-reset" onclick="confirmarReset()">🗑️ Resetar Dados</button>
        </div>
        <input type="file" id="fileInput" class="file-input" accept=".json" onchange="importarDados(this.files[0])">
    </div>

    <div class="tabs" id="tabs"></div>
    <div id="content"></div>
</div>

<div id="modal" class="modal">
    <div class="modal-content">
        <h3 id="modalTitle">Aviso</h3>
        <p id="modalMessage">Mensagem</p>
        <button onclick="fecharModal()" style="margin-top: 20px;">Fechar</button>
    </div>
</div>

<script>
    const STORAGE_KEYS = {
        CREDIT_CARDS: 'credit_cards_data',
        CREDIT_CARD_EXPENSES: 'credit_card_expenses',
        MONTHLY_DATA: 'monthly_data_50_30_20',
        INVESTMENTS: 'investments_complete'
    };

    const MONTHS = ["JAN","FEV","MAR","ABR","MAI","JUN","JUL","AGO","SET","OUT","NOV","DEZ"];
    const MONTH_NAMES = ["Janeiro","Fevereiro","Março","Abril","Maio","Junho",
                         "Julho","Agosto","Setembro","Outubro","Novembro","Dezembro"];

    let creditCards = [];
    let creditCardExpenses = [];
    let monthlyData = {};
    let investments = {
        fiis: [],
        acoes: [],
        tesouro_direto: []
    };
    let selectedCardId = null;
    let currentMonthIndex = 0;

    function mostrarModal(titulo, mensagem, isErro = false) {
        const modal = document.getElementById('modal');
        const title = document.getElementById('modalTitle');
        const message = document.getElementById('modalMessage');
        if (!modal) return;
        title.textContent = titulo;
        message.textContent = mensagem;
        title.style.color = isErro ? '#EF476F' : '#06D6A0';
        modal.style.display = 'flex';
    }

    function fecharModal() {
        const modal = document.getElementById('modal');
        if (modal) modal.style.display = 'none';
    }

    function showToast(mensagem, tipo = 'sucesso') {
        const toast = document.createElement('div');
        toast.style.cssText = `
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: ${tipo === 'erro' ? '#EF476F' : '#06D6A0'};
            color: white;
            padding: 12px 24px;
            border-radius: 8px;
            z-index: 1001;
            animation: fadeIn 0.3s ease-out;
            font-weight: bold;
        `;
        toast.textContent = mensagem;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 3000);
    }

    function calcularTamanhoStorage() {
        let total = 0;
        for (let key in localStorage) {
            if (localStorage.hasOwnProperty(key)) {
                total += localStorage[key].length;
            }
        }
        return total;
    }

    function formatarTamanho(bytes) {
        if (bytes < 1024) return bytes + ' B';
        if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(2) + ' KB';
        return (bytes / (1024 * 1024)).toFixed(2) + ' MB';
    }

    function atualizarStorageBar() {
        const tamanho = calcularTamanhoStorage();
        const percentual = (tamanho / (5 * 1024 * 1024)) * 100;
        const bar = document.getElementById('storageBar');
        if (bar) {
            bar.innerHTML = `💾 Usado: ${formatarTamanho(tamanho)} de ~5MB`;
            if (percentual > 80) {
                bar.style.background = '#EF476F';
            } else if (percentual > 50) {
                bar.style.background = '#FFD166';
            } else {
                bar.style.background = '#06D6A0';
            }
        }
    }

    function showStorageInfo() {
        const tamanho = calcularTamanhoStorage();
        const percentual = (tamanho / (5 * 1024 * 1024)) * 100;
        let status = percentual > 80 ? '⚠️ Crítico! Faça backup.' : (percentual > 50 ? '⚠️ Moderado.' : '✅ Saudável.');
        alert(`💾 Armazenamento\nUsado: ${formatarTamanho(tamanho)}\nLimite: ~5 MB\nUtilização: ${percentual.toFixed(1)}%\n\n${status}`);
    }

    function exportarDados() {
        const dados = {
            versao: "2.0",
            data_exportacao: new Date().toISOString(),
            creditCards: creditCards,
            creditCardExpenses: creditCardExpenses,
            monthlyData: monthlyData,
            investments: investments
        };
        
        const jsonStr = JSON.stringify(dados, null, 2);
        const blob = new Blob([jsonStr], {type: 'application/json'});
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        const data = new Date();
        const nomeArquivo = `backup_financeiro_${data.getFullYear()}-${(data.getMonth()+1).toString().padStart(2,'0')}-${data.getDate().toString().padStart(2,'0')}.json`;
        a.href = url;
        a.download = nomeArquivo;
        a.click();
        URL.revokeObjectURL(url);
        mostrarModal('✅ Backup Realizado', `Arquivo "${nomeArquivo}" salvo com sucesso!`);
    }

    function importarDados(file) {
        if (!file) return;
        
        const reader = new FileReader();
        reader.onload = function(e) {
            try {
                const dados = JSON.parse(e.target.result);
                
                if (!dados.creditCardExpenses || !dados.monthlyData || !dados.investments) {
                    throw new Error('Arquivo inválido. Estrutura não reconhecida.');
                }
                
                if (confirm('⚠️ ATENÇÃO: Isso irá SUBSTITUIR todos os dados atuais!\n\nDeseja continuar?')) {
                    creditCards = dados.creditCards || [];
                    creditCardExpenses = dados.creditCardExpenses;
                    monthlyData = dados.monthlyData;
                    investments = dados.investments;
                    
                    if (creditCards.length > 0 && creditCards[0].id) {
                        selectedCardId = creditCards[0].id;
                    } else if (creditCards.length === 0) {
                        adicionarCartaoPadrao();
                    }
                    
                    saveAllData();
                    refreshCurrentTab();
                    atualizarStorageBar();
                    
                    mostrarModal('✅ Importação Concluída', `Dados importados com sucesso!\nCartões: ${creditCards.length}\nGastos: ${creditCardExpenses.length} itens`);
                }
            } catch (error) {
                mostrarModal('❌ Erro na Importação', `Não foi possível importar: ${error.message}`, true);
            }
        };
        reader.readAsText(file);
        document.getElementById('fileInput').value = '';
    }

    function confirmarReset() {
        if (confirm('⚠️ ATENÇÃO! Isso irá APAGAR TODOS os dados!\n\nTem certeza absoluta?')) {
            if (confirm('ÚLTIMA CONFIRMAÇÃO: Todos os dados serão perdidos.')) {
                resetarTodosDados();
            }
        }
    }

    function resetarTodosDados() {
        localStorage.removeItem(STORAGE_KEYS.CREDIT_CARDS);
        localStorage.removeItem(STORAGE_KEYS.CREDIT_CARD_EXPENSES);
        localStorage.removeItem(STORAGE_KEYS.MONTHLY_DATA);
        localStorage.removeItem(STORAGE_KEYS.INVESTMENTS);
        
        loadInitialData();
        saveAllData();
        refreshCurrentTab();
        atualizarStorageBar();
        
        mostrarModal('🔄 Dados Resetados', 'Todos os dados foram resetados para os valores padrão.');
    }

    function adicionarCartaoPadrao() {
        creditCards = [];
        const cartao1 = { id: Date.now(), nome: "Cartão Principal", limite: 5000, fechamento: 10, vencimento: 25 };
        const cartao2 = { id: Date.now() + 1, nome: "Cartão Secundário", limite: 3000, fechamento: 15, vencimento: 30 };
        creditCards.push(cartao1, cartao2);
        selectedCardId = cartao1.id;
    }

    function adicionarCartao() {
        const nome = prompt("Nome do cartão:", "Novo Cartão");
        if (!nome) return;
        const limite = parseFloat(prompt("Limite do cartão (R$):", "5000"));
        const fechamento = parseInt(prompt("Dia de fechamento da fatura:", "10"));
        const vencimento = parseInt(prompt("Dia de vencimento:", "25"));
        
        const novoCartao = {
            id: Date.now(),
            nome: nome,
            limite: isNaN(limite) ? 5000 : limite,
            fechamento: isNaN(fechamento) ? 10 : fechamento,
            vencimento: isNaN(vencimento) ? 25 : vencimento
        };
        creditCards.push(novoCartao);
        if (creditCards.length === 1) selectedCardId = novoCartao.id;
        saveAllData();
        refreshCurrentTab();
        showToast(`Cartão "${nome}" adicionado!`);
    }

    function excluirCartao(cardId) {
        if (creditCards.length <= 1) {
            showToast("É necessário manter pelo menos um cartão!", "erro");
            return;
        }
        if (confirm("Excluir este cartão? Todas as compras associadas serão removidas.")) {
            creditCards = creditCards.filter(c => c.id !== cardId);
            creditCardExpenses = creditCardExpenses.filter(e => e.cartaoId !== cardId);
            if (selectedCardId === cardId && creditCards.length > 0) {
                selectedCardId = creditCards[0].id;
            }
            saveAllData();
            refreshCurrentTab();
            showToast("Cartão excluído!");
        }
    }

    function getDefaultMonthlyData(mes) {
        return {
            receita: mes === "JAN" ? 6384.01 : (mes === "FEV" ? 7081.81 : (mes === "JUL" ? 11426.60 : (mes === "DEZ" ? 9528.85 : 6631.81))),
            necessidades: [],   // 50% - antigo obrig_fixas + obrig_var
            desejos: [],        // 30% - antigo nao_obrig_fixas + nao_obrig_var + eventuais
            investimentos: []   // 20% - investimentos
        };
    }

    function loadInitialData() {
        const savedCards = localStorage.getItem(STORAGE_KEYS.CREDIT_CARDS);
        if (savedCards) {
            creditCards = JSON.parse(savedCards);
            const savedSelected = localStorage.getItem('selected_card_id');
            selectedCardId = savedSelected ? parseInt(savedSelected) : (creditCards[0]?.id || null);
        } else {
            adicionarCartaoPadrao();
        }

        const savedCardExpenses = localStorage.getItem(STORAGE_KEYS.CREDIT_CARD_EXPENSES);
        if (savedCardExpenses) {
            creditCardExpenses = JSON.parse(savedCardExpenses);
        } else {
            const cartaoId = creditCards[0]?.id || Date.now();
            creditCardExpenses = [
                { id: Date.now() + 1, cartaoId: cartaoId, nome: "Notebook (Trabalho)", valor: 3500, tipo: "parcelado", parcelas: 6, parcelaAtual: 1, dataInicio: "2026-01", categoria: "investimento" },
                { id: Date.now() + 2, cartaoId: cartaoId, nome: "Netflix", valor: 45.90, tipo: "recorrente", parcelas: 0, parcelaAtual: 0, dataInicio: "2026-01", categoria: "desejo" },
                { id: Date.now() + 3, cartaoId: cartaoId, nome: "Mercado", valor: 850, tipo: "vista", parcelas: 0, parcelaAtual: 0, dataInicio: "2026-01", categoria: "necessidade" }
            ];
        }

        const savedMonthly = localStorage.getItem(STORAGE_KEYS.MONTHLY_DATA);
        if (savedMonthly) {
            monthlyData = JSON.parse(savedMonthly);
        } else {
            MONTHS.forEach(m => {
                monthlyData[m] = getDefaultMonthlyData(m);
            });
            
            // Dados de exemplo para Janeiro
            monthlyData["JAN"].necessidades = [
                { nome: "Aluguel", valor: 1500 },
                { nome: "Mercado", valor: 800 },
                { nome: "Conta de Luz", valor: 120 },
                { nome: "Transporte", valor: 300 }
            ];
            monthlyData["JAN"].desejos = [
                { nome: "Netflix/Streaming", valor: 90 },
                { nome: "Restaurante", valor: 250 },
                { nome: "Cinema", valor: 60 },
                { nome: "Roupas", valor: 200 }
            ];
            monthlyData["JAN"].investimentos = [
                { nome: "Curso Profissionalizante", valor: 200 },
                { nome: "Ações", valor: 300 }
            ];
            
            // Dados de exemplo para Fevereiro
            monthlyData["FEV"].necessidades = [
                { nome: "Aluguel", valor: 1500 },
                { nome: "Mercado", valor: 750 },
                { nome: "Conta de Luz", valor: 115 }
            ];
            monthlyData["FEV"].desejos = [
                { nome: "Streaming", valor: 90 },
                { nome: "Viagem", valor: 500 }
            ];
            monthlyData["FEV"].investimentos = [
                { nome: "Tesouro Direto", valor: 400 }
            ];
        }

        const savedInv = localStorage.getItem(STORAGE_KEYS.INVESTMENTS);
        if (savedInv) {
            investments = JSON.parse(savedInv);
        } else {
            investments = {
                fiis: [{ nome: "HGBS11", quantidade: 100, preco_medio: 98.50, valor_atual: 102.30 }],
                acoes: [{ nome: "PETR4", quantidade: 200, preco_medio: 32.50, valor_atual: 36.80 }],
                tesouro_direto: [{ nome: "Tesouro Selic 2029", valor_investido: 5000, valor_atual: 5230 }]
            };
        }
    }

    function saveAllData() {
        localStorage.setItem(STORAGE_KEYS.CREDIT_CARDS, JSON.stringify(creditCards));
        localStorage.setItem(STORAGE_KEYS.CREDIT_CARD_EXPENSES, JSON.stringify(creditCardExpenses));
        localStorage.setItem(STORAGE_KEYS.MONTHLY_DATA, JSON.stringify(monthlyData));
        localStorage.setItem(STORAGE_KEYS.INVESTMENTS, JSON.stringify(investments));
        if (selectedCardId) localStorage.setItem('selected_card_id', selectedCardId.toString());
        atualizarStorageBar();
    }

    function getParcelasMes(mes, ano = 2026, cartaoId = null) {
        const mesNum = MONTHS.indexOf(mes) + 1;
        const dataReferencia = `${ano}-${mesNum.toString().padStart(2,'0')}`;
        let total = 0;
        let detalhes = [];
        const filteredExpenses = cartaoId ? creditCardExpenses.filter(e => e.cartaoId === cartaoId) : creditCardExpenses;

        filteredExpenses.forEach(expense => {
            const dataInicio = expense.dataInicio;
            if (expense.tipo === 'vista') {
                if (dataInicio === dataReferencia) {
                    total += expense.valor;
                    detalhes.push({ ...expense, valorParcela: expense.valor });
                }
            } else if (expense.tipo === 'parcelado') {
                const [anoIni, mesIni] = dataInicio.split('-').map(Number);
                const parcelaInicio = (anoIni - ano) * 12 + (mesIni - mesNum);
                if (parcelaInicio >= 0 && parcelaInicio < expense.parcelas) {
                    const valorParcela = expense.valor / expense.parcelas;
                    total += valorParcela;
                    detalhes.push({ ...expense, valorParcela, parcelaNum: parcelaInicio + 1 });
                }
            } else if (expense.tipo === 'recorrente') {
                total += expense.valor;
                detalhes.push({ ...expense, valorParcela: expense.valor });
            }
        });
        return { total, detalhes };
    }

    function getTotalGastosCartaoMes(mes, cartaoId = null) {
        if (cartaoId) return getParcelasMes(mes, 2026, cartaoId).total;
        let totalGeral = 0;
        creditCards.forEach(card => {
            totalGeral += getParcelasMes(mes, 2026, card.id).total;
        });
        return totalGeral;
    }

    function getTotalByCategory(mes, categoria) {
        if (!monthlyData[mes]) return 0;
        const items = monthlyData[mes][categoria] || [];
        return items.reduce((sum, item) => sum + (item.valor || 0), 0);
    }

    function getReceita(mes) { return monthlyData[mes]?.receita || 0; }
    function getTotalNecessidades(mes) { return getTotalByCategory(mes, 'necessidades'); }
    function getTotalDesejos(mes) { return getTotalByCategory(mes, 'desejos'); }
    function getTotalInvestimentosMensal(mes) { return getTotalByCategory(mes, 'investimentos'); }
    function getTotalDespesasMes(mes) { return getTotalNecessidades(mes) + getTotalDesejos(mes) + getTotalInvestimentosMensal(mes) + getTotalGastosCartaoMes(mes); }
    function getSaldo(mes) { return getReceita(mes) - getTotalDespesasMes(mes); }

    function formatCurrency(v) { return new Intl.NumberFormat('pt-BR',{style:'currency',currency:'BRL'}).format(v||0); }
    function formatPercent(v) { return new Intl.NumberFormat('pt-BR',{style:'percent',minimumFractionDigits:1}).format(v); }

